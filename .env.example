# OpenAI — ChatGPT (сырой POST …/v1/chat/completions, в ответе usage)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek (POST …/chat/completions)
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Perplexity (запросы идут на POST /v1/sonar — там же приходит usage)
PERPLEXITY_API_KEY=
# PERPLEXITY_API_URL=https://api.perplexity.ai/v1/sonar

# Google AI Studio — ключ Gemini
GOOGLE_AI_API_KEY=

# Yandex Cloud — Алиса AI (OpenAI-совместимый эндпоинт)
YANDEX_CLOUD_FOLDER_ID=
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_MODEL=aliceai-llm/latest
# YANDEX_RESPONSES_URL=https://ai.api.cloud.yandex.net/v1/responses

# Yandex Cloud Search API — генеративный ответ по веб-поиску (провайдер alice_search).
# По умолчанию те же YANDEX_CLOUD_*; при необходимости задайте отдельно:
# YANDEX_GEN_SEARCH_FOLDER_ID=
# YANDEX_GEN_SEARCH_API_KEY=
# YANDEX_GEN_SEARCH_URL=https://searchapi.api.cloud.yandex.net/v2/gen/search
# YANDEX_GEN_SEARCH_SEARCH_TYPE=SEARCH_TYPE_RU

# Опционально: модель Gemini (по умолчанию цепочка: gemini-2.5-flash → 2.0 → …)
# GOOGLE_GEMINI_MODEL=gemini-2.5-flash

# Параллельных «пользовательских» запросов в пакете (1–16, по умолчанию 4)
# BATCH_QUERY_CONCURRENCY=4

# Параллельных ячеек (запрос × модель) в потоке SSE /api/query/stream (1–24, по умолчанию 12)
# STREAM_CELL_CONCURRENCY=12

# Опционально: защита POST /api/query для внешних вызовов (Postman, скрипты). Без ключа — как раньше, без проверки.
# API_SECRET=длинный-случайный-секрет
# Тогда: Authorization: Bearer <секрет>  или  X-API-Key: <секрет>

# Опционально: HTTP Basic только для сайта (/, статика, /openapi.json, /api-docs/) — не для /api/* (там свой Bearer при API_SECRET).
# SITE_BASIC_AUTH_USER=
# SITE_BASIC_AUTH_PASSWORD=

# Логи (JSONL, одна строка = один JSON). Каталог и файл создаются сами; файл можно удалить — появится снова.
# LOG_DIR=./logs
# LOG_FILE=app.log
# LOG_LEVEL=info
# Уровни: debug | info | warn | error (debug — ещё и усечённые превью тел POST /api/query*)
# За nginx оставьте доверие к X-Forwarded-For (по умолчанию включено). Локально без прокси: TRUST_PROXY=0
# TRUST_PROXY=0