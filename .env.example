# OpenAI — ChatGPT (сырой POST …/v1/chat/completions, в ответе usage)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek (POST …/chat/completions)
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Perplexity (запросы идут на POST /v1/sonar — там же приходит usage)
PERPLEXITY_API_KEY=
# PERPLEXITY_API_URL=https://api.perplexity.ai/v1/sonar

# Google AI Studio — ключ Gemini
GOOGLE_AI_API_KEY=

# Yandex Cloud — Алиса AI (OpenAI-совместимый эндпоинт)
YANDEX_CLOUD_FOLDER_ID=
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_MODEL=aliceai-llm/latest
# YANDEX_RESPONSES_URL=https://ai.api.cloud.yandex.net/v1/responses

# Опционально: модель Gemini (по умолчанию цепочка: gemini-2.5-flash → 2.0 → …)
# GOOGLE_GEMINI_MODEL=gemini-2.5-flash